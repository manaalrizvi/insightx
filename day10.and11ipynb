   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "months = [\"Jan\",\"Feb\",\"Mar\",\"Apr\",\"May\",\"Jun\",\"Jul\",\"Aug\",\"Sep\",\"Oct\",\"Nov\",\"Dec\"]\n",
    "sales = [120,150,170,200,220,250,270,300,320,350,370,400]\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "\n",
    "plt.plot(\n",
    "    months,\n",
    "    sales,\n",
    "    color=\"blue\",\n",
    "    marker=\"o\",\n",
    "    linestyle=\"--\",\n",
    "    linewidth=2,\n",
    "    markersize=8\n",
    ")\n",
    "\n",
    "plt.title(\"Growth of Sales Over 12 Months\", fontsize=16)\n",
    "plt.xlabel(\"Months\", fontsize=12)\n",
    "plt.ylabel(\"Sales\", fontsize=12)\n",
    "\n",
    "plt.grid(True)\n",
    "plt.xticks(rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "6551d676-0037-4668-becd-b541f477536f",
