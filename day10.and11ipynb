   "source": [
    "import seaborn as sns\n",
    "\n",
    "tips = sns.load_dataset(\"tips\")\n",
    "\n",
    "sns.boxplot(x=\"day\", y=\"tip\", data=tips)\n",
    "\n",
    "plt.title(\"Tip Distribution by Day\")\n",
    "plt.xlabel(\"Day of the Week\")\n",
    "plt.ylabel(\"Tip Amount\")\n",
    "\n",
    "plt.show()"
   ]
  },
